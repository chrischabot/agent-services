log "verifying proof packet"
"$ARCWELL_BIN" --home "$ARCWELL_HOME_USED" proof verify-packet "$ARTIFACT_DIR/proof-packet.json" \
  >"$ARTIFACT_DIR/verify-packet.json"
node - "$ARTIFACT_DIR/verify-packet.json" <<'NODE'
const fs = require("fs");
const report = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (report.ok !== true) {
  console.error(JSON.stringify(report, null, 2));
  process.exit(1);
}
NODE

if [[ "$RECORD" == "1" ]]; then
  log "recording durable proof packet and promote review"
  PACKET_ID="$("$ARCWELL_BIN" --home "$ARCWELL_HOME_USED" proof record \
    --scope autonomous-knowledge-system \
    --title "M1 X watch curation current manual review proof" \
    --proof-level real_home_current_review_drop_manual_review \
    --status partial \
    --summary "Reviewed 29 current review-drop rows, imported 18 keep rules and 10 exclude rules, pause-only applied exactly the 10 excludes, and left Earendil unresolved because it has zero local evidence." \
    --artifact-root "$PROOF_ROOT" \
    --reviewer codex \
    --claims-json "$(cat "$ARTIFACT_DIR/claims.json")" \
    --artifacts-json "$(cat "$ARTIFACT_DIR/artifacts.json")" \
    --checks-json "$(cat "$ARTIFACT_DIR/checks.json")" \
    --metadata-json "$(cat "$ARTIFACT_DIR/metadata.json")" \
    >"$ARTIFACT_DIR/recorded-proof.json" && node - "$ARTIFACT_DIR/recorded-proof.json" <<'NODE'
const fs = require("fs");
const report = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
process.stdout.write(report.packet?.id || report.id || "");
NODE
  )"
  [[ -n "$PACKET_ID" ]] || fail "proof record did not return a packet id"
  "$ARCWELL_BIN" --home "$ARCWELL_HOME_USED" proof review-record \
    --scope autonomous-knowledge-system \
    --title "M1 X watch curation current manual review review" \
    --reviewer codex \
    --requested-proof-level real_home_current_review_drop_manual_review \
    --judgment promote \
    --summary "Promote this current-list manual review slice: the evidence-backed rules changed exactly the intended handles and preserved the unresolved zero-evidence boundary." \
    --strongest-fake-done-path "Claiming M1 is fully complete even though Earendil remains unresolved and recurrence/ops/gold-set gates remain open." \
    --packet-id "$PACKET_ID" \
    --refutations-json '["The proof verifies the previous real-home apply packet before mutation.", "The proof creates a private backup before mutation.", "Validation shows exactly the reviewed excludes changed status and reviewed keeps remained active.", "Earendil remains explicitly unresolved instead of being silently classified."]' \
    --skipped-categories-json '["No live provider re-enrichment was performed for Earendil.", "No multi-day recurrence proof was attempted.", "No ops UI control or MCP/slash parity proof was attempted."]' \
    --findings-json '[]' \
    --metadata-json "{\"packet_id\":\"$PACKET_ID\",\"gate\":\"x-watch-curation-current-manual-review\"}" \
    >"$ARTIFACT_DIR/review-recorded.json"
fi

log "wrote $ARTIFACT_DIR/proof-packet.json"
node - "$ARTIFACT_DIR/verify-packet.json" "$ARTIFACT_DIR/recorded-proof.json" 2>/dev/null <<'NODE' || true
const fs = require("fs");
const verify = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
const recordedPath = process.argv[3];
let packetId = null;
if (recordedPath && fs.existsSync(recordedPath)) {
  const recorded = JSON.parse(fs.readFileSync(recordedPath, "utf8"));
  packetId = recorded.packet?.id || recorded.id || null;
}
console.log(JSON.stringify({ verify_ok: verify.ok, packet_id: packetId }, null, 2));
NODE
