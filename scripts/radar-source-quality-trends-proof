#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

if ! command -v node >/dev/null 2>&1; then
  echo "BLOCKED: node is required for JSON assertions." >&2
  exit 2
fi

RUN_STAMP="${ARCWELL_RADAR_SOURCE_TRENDS_PROOF_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_RADAR_SOURCE_TRENDS_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/radar-source-quality-trends-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
export ARCWELL_HOME="${ARCWELL_RADAR_SOURCE_TRENDS_PROOF_HOME:-$PROOF_ROOT/home}"

GITHUB_OWNER="${ARCWELL_RADAR_SOURCE_TRENDS_GITHUB_OWNER:-Thysrael}"
ARXIV_QUERY="${ARCWELL_RADAR_SOURCE_TRENDS_ARXIV_QUERY:-cat:cs.AI}"
HACKERNEWS_FEED="${ARCWELL_RADAR_SOURCE_TRENDS_HACKERNEWS_FEED:-frontpage}"
PROFILE_NAME="${ARCWELL_RADAR_SOURCE_TRENDS_PROFILE_NAME:-source-trends-proof-$RUN_STAMP}"
RUN_COUNT="${ARCWELL_RADAR_SOURCE_TRENDS_RUN_COUNT:-2}"
MIN_ITEMS_PER_RUN="${ARCWELL_RADAR_SOURCE_TRENDS_MIN_ITEMS_PER_RUN:-10}"
MIN_TREND_WINDOWS="${ARCWELL_RADAR_SOURCE_TRENDS_MIN_TREND_WINDOWS:-2}"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[radar-source-trends-proof] %s\n' "$*"
}

fail() {
  printf '[radar-source-trends-proof] BLOCKED: %s\n' "$*" >&2
  exit 2
}

case "$RUN_COUNT" in
  ''|*[!0-9]*) fail "RUN_COUNT must be a positive integer" ;;
esac
if [ "$RUN_COUNT" -lt 2 ] || [ "$RUN_COUNT" -gt 5 ]; then
  fail "RUN_COUNT must be between 2 and 5"
fi

log "proof root: $PROOF_ROOT"
log "ARCWELL_HOME: $ARCWELL_HOME"
log "creating live radar profile: $PROFILE_NAME"

"$ARCWELL_BIN" radar profile create "$PROFILE_NAME" \
  --description "Production-data source-quality trend proof over repeated public GitHub, arXiv, and Hacker News runs." \
  --window-hours 168 \
  --min-score 1 \
  --max-items 30 \
  --selector-json "{\"kind\":\"github_owner\",\"locator\":\"$GITHUB_OWNER\",\"limit\":10}" \
  --selector-json "{\"kind\":\"arxiv\",\"locator\":\"$ARXIV_QUERY\",\"limit\":10}" \
  --selector-json "{\"kind\":\"hackernews\",\"locator\":\"$HACKERNEWS_FEED\",\"limit\":5}" \
  >"$ARTIFACT_DIR/profile.json"

RUN_IDS=()
for run_index in $(seq 1 "$RUN_COUNT"); do
  log "running live radar pass $run_index/$RUN_COUNT"
  "$ARCWELL_BIN" radar run "$PROFILE_NAME" --window-hours 168 --fetch-live \
    >"$ARTIFACT_DIR/run-$run_index.json"
  RUN_ID="$(node - "$ARTIFACT_DIR/run-$run_index.json" "$MIN_ITEMS_PER_RUN" <<'NODE'
const fs = require("fs");
const [runPath, minItemsRaw] = process.argv.slice(2);
const minItems = Number(minItemsRaw);
const report = JSON.parse(fs.readFileSync(runPath, "utf8"));
function fail(message, detail) {
  console.error(message);
  if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
  process.exit(1);
}
if (!report.run || !report.run.id) fail("radar report has no run id", report);
if (report.run.status !== "scored") fail("radar run did not reach scored status", report.run);
if (Number(report.items_inserted || 0) < minItems) fail("radar run inserted too few real items", report);
if (Number(report.scores_inserted || 0) < Number(report.items_inserted || 0)) {
  fail("radar run did not score all inserted items", report);
}
const jobs = Array.isArray(report.adapter_jobs) ? report.adapter_jobs : [];
const failed = jobs.filter((job) => job.status !== "completed");
if (failed.length) fail("one or more adapter jobs failed", failed);
const kinds = new Set(jobs.map((job) => job.kind));
for (const expected of ["github_owner", "arxiv_search", "hackernews_fetch"]) {
  if (!kinds.has(expected)) fail(`missing adapter job ${expected}`, jobs);
}
if (Number(report.run?.metadata?.source_quality_windows || 0) < 1) {
  fail("radar run did not record source-quality windows", report.run?.metadata);
}
process.stdout.write(report.run.id);
NODE
)"
  RUN_IDS+=("$RUN_ID")
  "$ARCWELL_BIN" radar audit "$RUN_ID" >"$ARTIFACT_DIR/audit-$run_index.json"
  "$ARCWELL_BIN" radar source-quality "$RUN_ID" >"$ARTIFACT_DIR/source-quality-$run_index.json"
done

"$ARCWELL_BIN" radar source-quality-trends --min-windows "$MIN_TREND_WINDOWS" --limit 25 \
  >"$ARTIFACT_DIR/source-quality-trends.json"
"$ARCWELL_BIN" ops >"$ARTIFACT_DIR/ops.json"
"$ARCWELL_BIN" cursors list >"$ARTIFACT_DIR/cursors.json"

RUN_IDS_JSON="$(printf '%s\n' "${RUN_IDS[@]}" | node -e 'const fs=require("fs"); console.log(JSON.stringify(fs.readFileSync(0,"utf8").trim().split(/\n/).filter(Boolean)))')"

log "validating source-quality trend proof artifacts"
node - "$ARTIFACT_DIR" "$PROOF_ROOT" "$RUN_IDS_JSON" "$GITHUB_OWNER" "$ARXIV_QUERY" "$MIN_TREND_WINDOWS" <<'NODE'
const fs = require("fs");
const path = require("path");
const [
  artifactDir,
  proofRoot,
  runIdsJson,
  githubOwner,
  arxivQuery,
  minTrendWindowsRaw,
] = process.argv.slice(2);
const runIds = JSON.parse(runIdsJson);
const minTrendWindows = Number(minTrendWindowsRaw);
const read = (name) => JSON.parse(fs.readFileSync(path.join(artifactDir, name), "utf8"));

function assert(condition, message, detail) {
  if (!condition) {
    console.error(`FAIL: ${message}`);
    if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
    process.exit(1);
  }
}

const profile = read("profile.json");
const trends = read("source-quality-trends.json");
const ops = read("ops.json");
const cursors = read("cursors.json");
const audits = runIds.map((_, index) => read(`audit-${index + 1}.json`));
const sourceQualityByRun = runIds.map((_, index) => read(`source-quality-${index + 1}.json`));
const reports = runIds.map((_, index) => read(`run-${index + 1}.json`));

assert(profile.status === "local_proof_ready", "profile should be supported by local projection", profile);
assert(runIds.length >= 2, "proof requires at least two runs", runIds);
assert(audits.every((audit) => audit.ok === true), "every run audit should pass", audits);
assert(
  sourceQualityByRun.every((rows) => Array.isArray(rows) && rows.length >= 1),
  "each run should expose source-quality rows",
  sourceQualityByRun
);
assert(Array.isArray(trends) && trends.length >= 1, "trend command should return at least one ranked source", trends);

const qualified = trends.filter((trend) => Number(trend.window_count || 0) >= minTrendWindows);
assert(qualified.length >= 1, "at least one source should satisfy min window history", trends);
assert(
  qualified.every((trend) => Number(trend.raw_count || 0) >= Number(trend.window_count || 0)),
  "trend raw counts should cover all windows",
  qualified
);
assert(
  qualified.every((trend) => Number(trend.quality_score || 0) >= 0 && Number(trend.quality_score || 0) <= 10),
  "trend quality scores should stay bounded",
  qualified
);
const sorted = [...trends].sort((a, b) => Number(b.quality_score || 0) - Number(a.quality_score || 0));
assert(
  trends[0].source_kind === sorted[0].source_kind &&
    trends[0].locator === sorted[0].locator &&
    Number(trends[0].quality_score || 0) === Number(sorted[0].quality_score || 0),
  "trend rows should be quality-ranked",
  trends
);

const sourceQualityKeys = new Set();
for (const rows of sourceQualityByRun) {
  for (const row of rows) sourceQualityKeys.add(`${row.source_kind}:${row.locator}`);
}
assert(
  qualified.some((trend) => sourceQualityKeys.has(`${trend.source_kind}:${trend.locator}`)),
  "trend rows should correspond to source-quality rows from the live runs",
  { qualified, sourceQualityKeys: [...sourceQualityKeys] }
);

const sourceHealth = Array.isArray(ops.source_health) ? ops.source_health : [];
const hasHealthy = (provider, locatorNeedle) =>
  sourceHealth.some((row) =>
    row.provider === provider &&
    row.status === "healthy" &&
    String(row.locator || row.key || "").includes(locatorNeedle)
  );
assert(hasHealthy("github", githubOwner), "ops should show healthy GitHub source", sourceHealth);
assert(hasHealthy("arxiv", arxivQuery), "ops should show healthy arXiv source", sourceHealth);
assert(hasHealthy("hackernews", "topstories"), "ops should show healthy Hacker News source", sourceHealth);

const cursorKeys = new Set((cursors || []).map((cursor) => cursor.key));
assert(cursorKeys.has(`github-owner:${githubOwner}`), "GitHub cursor should exist", cursors);
assert(cursorKeys.has(`arxiv:${arxivQuery}`), "arXiv cursor should exist", cursors);
assert(cursorKeys.has("hackernews:topstories"), "Hacker News cursor should exist", cursors);

const proofPacket = {
  proof_name: "radar-source-quality-trends-proof",
  proof_level: "Production Data Proof for local source-quality ranking over repeated live public radar runs",
  proof_root: proofRoot,
  arcwell_home: process.env.ARCWELL_HOME,
  run_ids: runIds,
  profile_id: profile.id,
  profile_name: profile.name,
  source_families: [
    { provider: "github", locator: githubOwner },
    { provider: "arxiv", locator: arxivQuery },
    { provider: "hackernews", locator: "frontpage/topstories" },
  ],
  runs: reports.map((report) => ({
    run_id: report.run.id,
    status: report.run.status,
    items_inserted: report.items_inserted,
    scores_inserted: report.scores_inserted,
    selected_items: report.selected_items,
    source_quality_windows: report.run.metadata.source_quality_windows,
    exact_dedup_groups: report.run.metadata.exact_dedup_groups,
    semantic_dedup_groups: report.run.metadata.semantic_dedup_groups,
  })),
  trend_summary: {
    trend_count: trends.length,
    min_windows: minTrendWindows,
    top_trend: trends[0],
    qualified_count: qualified.length,
  },
  audits: audits.map((audit) => ({
    ok: audit.ok,
    run_id: audit.run_id,
    item_count: audit.item_count,
    fts_count: audit.fts_count,
    scored_count: audit.scored_count,
    source_quality_count: audit.source_quality_count,
    finding_count: audit.findings.length,
  })),
  cursor_keys: [...cursorKeys].filter((key) =>
    key === `github-owner:${githubOwner}` ||
    key === `arxiv:${arxivQuery}` ||
    key === "hackernews:topstories"
  ),
  remaining_risk: [
    "This proves repeated live public runs in a disposable home, not seven-day scheduled decay/staleness behavior.",
    "It does not prove authenticated X, Reddit OAuth, model synthesis, delivery attempts, or production notification routing.",
  ],
};

fs.writeFileSync(
  path.join(artifactDir, "proof-packet.json"),
  `${JSON.stringify(proofPacket, null, 2)}\n`
);
process.stdout.write(JSON.stringify(proofPacket, null, 2));
NODE

printf '\n'
log "source-quality trend production-data proof passed"
log "proof packet: $ARTIFACT_DIR/proof-packet.json"
