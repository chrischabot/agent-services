#!/usr/bin/env node
"use strict";

const childProcess = require("child_process");
const fs = require("fs");

const EMAIL_RE = /[A-Za-z0-9._%+-]+@([A-Za-z0-9.-]+\.[A-Za-z]{2,})/g;
const EXCLUDED_RE = /(^|\/)(Cargo\.lock|package-lock\.json|pnpm-lock\.yaml|yarn\.lock)$/;

function git(args) {
  const result = childProcess.spawnSync("git", args, {
    encoding: "utf8",
    maxBuffer: 16 * 1024 * 1024,
  });
  if (result.error) throw result.error;
  if (result.status !== 0) {
    throw new Error(`git ${args.join(" ")} failed:\n${result.stderr}`);
  }
  return result.stdout;
}

function isAllowedDomain(domain) {
  const normalized = domain.toLowerCase();
  return (
    normalized === "example.com" ||
    normalized === "example.org" ||
    normalized === "example.net" ||
    normalized.endsWith(".test")
  );
}

function lineNumberAt(text, index) {
  let line = 1;
  for (let i = 0; i < index; i += 1) {
    if (text.charCodeAt(i) === 10) line += 1;
  }
  return line;
}

function check() {
  const files = git(["ls-files", "-z"])
    .split("\0")
    .filter(Boolean)
    .filter((file) => !EXCLUDED_RE.test(file));
  const failures = [];
  let scanned = 0;

  for (const file of files) {
    let text;
    try {
      text = fs.readFileSync(file, "utf8");
    } catch {
      continue;
    }
    scanned += 1;
    for (const match of text.matchAll(EMAIL_RE)) {
      const address = match[0];
      const domain = match[1];
      if (!isAllowedDomain(domain)) {
        failures.push(`${file}:${lineNumberAt(text, match.index)}: ${address}`);
      }
    }
  }

  if (failures.length > 0) {
    console.error("Tracked files contain non-placeholder email addresses:");
    for (const failure of failures) console.error(`  ${failure}`);
    console.error("Use example.com/example.org/example.net/.test in tracked files; put real addresses in ignored env or Arcwell secrets.");
    process.exit(1);
  }

  console.log(`tracked email placeholder check passed (${scanned} tracked text files scanned)`);
}

check();
