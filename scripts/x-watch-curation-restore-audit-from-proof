log "verifying proof packet"
"$ARCWELL_BIN" --home "$ARCWELL_HOME_USED" proof verify-packet "$ARTIFACT_DIR/proof-packet.json" >"$ARTIFACT_DIR/verify-packet.json"
node - "$ARTIFACT_DIR/verify-packet.json" <<'NODE'
const fs = require("fs");
const report = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (report.ok !== true) {
  console.error(JSON.stringify(report, null, 2));
  process.exit(1);
}
NODE

if [[ "$RECORD" == "1" ]]; then
  log "recording durable proof packet and promote review"
  PACKET_ID="$("$ARCWELL_BIN" --home "$ARCWELL_HOME_USED" proof record \
    --scope autonomous-knowledge-system \
    --title "M1 historical X watch curation audit recovery" \
    --proof-level reviewed_artifact_recovery_plus_live_db_import \
    --status partial \
    --summary "Recovered the 2026-06-29 real-home pause-only X curation decisions/evidence from the reviewed proof artifact into the live DB. Restore snapshots remain unreconstructed because the artifact lacks full previous metadata_json." \
    --artifact-root "$PROOF_ROOT" \
    --reviewer codex \
    --claims-json "$(cat "$ARTIFACT_DIR/claims.json")" \
    --artifacts-json "$(cat "$ARTIFACT_DIR/artifacts.json")" \
    --checks-json "$(cat "$ARTIFACT_DIR/checks.json")" \
    --metadata-json "$(cat "$ARTIFACT_DIR/metadata.json")" \
    >"$ARTIFACT_DIR/recorded-proof.json" && node - "$ARTIFACT_DIR/recorded-proof.json" <<'NODE'
const fs = require("fs");
const report = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
process.stdout.write(report.packet?.id || report.id || "");
NODE
  )"
  [[ -n "$PACKET_ID" ]] || fail "proof record did not return a packet id"
  "$ARCWELL_BIN" --home "$ARCWELL_HOME_USED" proof review-record \
    --scope autonomous-knowledge-system \
    --title "M1 historical X watch curation audit recovery review" \
    --reviewer codex \
    --requested-proof-level reviewed_artifact_recovery_plus_live_db_import \
    --judgment promote \
    --summary "Promote this narrow recovery: historical 2026-06-29 curation decisions/evidence are back in the live DB with exact artifact hashes. Hold exact restore and M1 operational claims." \
    --strongest-fake-done-path "Treating recovered decisions/evidence as proof that exact restore snapshots were rebuilt, that current watch-source quality is good, or that M1 is operational." \
    --packet-id "$PACKET_ID" \
    --refutations-json '["Copied-home rehearsal passed before real import.", "Live DB row hashes match the reviewed source artifact.", "Watch-source status counts were unchanged by the import.", "Proof packet explicitly marks restore snapshots unreconstructed."]' \
    --skipped-categories-json '["Historical exact restore snapshots not reconstructed because full previous metadata_json is unavailable.", "Worker-pressure and source-health improvement remain separate gates.", "Gold-set classifier quality remains separate."]' \
    --findings-json '[]' \
    --metadata-json "{\"packet_id\":\"$PACKET_ID\",\"gate\":\"x-watch-curation-historical-audit-recovery\"}" \
    >"$ARTIFACT_DIR/review-recorded.json"
fi

log "wrote $ARTIFACT_DIR/proof-packet.json"
node - "$ARTIFACT_DIR/verify-packet.json" "$ARTIFACT_DIR/recorded-proof.json" 2>/dev/null <<'NODE' || true
const fs = require("fs");
const verify = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
let packetId = null;
if (process.argv[3] && fs.existsSync(process.argv[3])) {
  const recorded = JSON.parse(fs.readFileSync(process.argv[3], "utf8"));
  packetId = recorded.packet?.id || recorded.id || null;
}
console.log(JSON.stringify({ ok: verify.ok, packet_id: packetId }, null, 2));
NODE
