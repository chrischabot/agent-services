#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

if ! command -v agent-browser >/dev/null 2>&1; then
  echo "BLOCKED: agent-browser is required for /ops/ui browser smoke." >&2
  exit 2
fi

for required in node curl; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "BLOCKED: $required is required for /ops/ui browser smoke." >&2
    exit 2
  fi
done

RUN_STAMP="${ARCWELL_OPS_UI_BROWSER_SMOKE_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_OPS_UI_BROWSER_SMOKE_DIR:-$REPO_ROOT/.arcwell-dev/proofs/ops-ui-browser-smoke-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
export ARCWELL_HOME="${ARCWELL_OPS_UI_BROWSER_SMOKE_HOME:-$PROOF_ROOT/home}"
AUTH_TOKEN="${ARCWELL_OPS_UI_BROWSER_SMOKE_TOKEN:-ops-ui-browser-smoke-token-$RUN_STAMP}"
SESSION="arcwell-ops-ui-smoke-$RUN_STAMP"
PROFILE_NAME="ops-ui-browser-smoke-$RUN_STAMP"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[ops-ui-browser-smoke] %s\n' "$*"
}

cleanup() {
  if [ -n "${SERVER_PID:-}" ] && kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    kill "$SERVER_PID" >/dev/null 2>&1 || true
    wait "$SERVER_PID" >/dev/null 2>&1 || true
  fi
  agent-browser --session "$SESSION" close >/dev/null 2>&1 || true
}
trap cleanup EXIT

PORT="$(node -e 'const net=require("net"); const server=net.createServer(); server.listen(0,"127.0.0.1",()=>{ const {port}=server.address(); console.log(port); server.close(); });')"
BASE_URL="http://127.0.0.1:$PORT"

log "proof root: $PROOF_ROOT"
log "ARCWELL_HOME: $ARCWELL_HOME"
log "seeding source cards and radar run"

"$ARCWELL_BIN" source-card add \
  --title "Ops browser launch benchmark" \
  --url "https://example.com/ops-browser-launch" \
  --source-type article \
  --provider fixture \
  --summary "Launch benchmark for an ops browser smoke over a model agent platform with enough source-card text to score." \
  >"$ARTIFACT_DIR/source-card-launch.json"

"$ARCWELL_BIN" source-card add \
  --title "Ops browser security release" \
  --url "https://example.com/ops-browser-security" \
  --source-type article \
  --provider fixture \
  --summary "Security vulnerability release for an open source MCP agent runtime used to populate radar score distribution rows." \
  >"$ARTIFACT_DIR/source-card-security.json"

"$ARCWELL_BIN" source-card add \
  --title "Ops browser hostile <script>alert(1)</script>" \
  --url "https://example.com/ops-browser-hostile" \
  --source-type article \
  --provider fixture \
  --summary "Hostile source text says <img src=x onerror=alert(1)> and must render as inert text in ops." \
  >"$ARTIFACT_DIR/source-card-hostile.json"

"$ARCWELL_BIN" radar profile create "$PROFILE_NAME" \
  --description "Ops UI browser smoke radar profile" \
  --window-hours 24 \
  --min-score 1 \
  --max-items 2 \
  --source-card-query "Ops browser" \
  >"$ARTIFACT_DIR/radar-profile.json"

"$ARCWELL_BIN" radar run "$PROFILE_NAME" >"$ARTIFACT_DIR/radar-run.json"
"$ARCWELL_BIN" ops >"$ARTIFACT_DIR/ops.json"

log "starting authenticated local HTTP server on $BASE_URL"
"$ARCWELL_BIN" serve --addr "127.0.0.1:$PORT" --auth-token "$AUTH_TOKEN" \
  >"$ARTIFACT_DIR/server.log" 2>&1 &
SERVER_PID="$!"

for _ in $(seq 1 80); do
  if curl -fsS -H "x-arcwell-http-token: $AUTH_TOKEN" "$BASE_URL/health" >/dev/null 2>&1; then
    break
  fi
  if ! kill -0 "$SERVER_PID" >/dev/null 2>&1; then
    echo "BLOCKED: HTTP server exited before readiness. See $ARTIFACT_DIR/server.log" >&2
    exit 2
  fi
  sleep 0.1
done

if ! curl -fsS -H "x-arcwell-http-token: $AUTH_TOKEN" "$BASE_URL/health" >/dev/null 2>&1; then
  echo "BLOCKED: HTTP server did not become ready. See $ARTIFACT_DIR/server.log" >&2
  exit 2
fi

agent-browser --session "$SESSION" set headers "{\"x-arcwell-http-token\":\"$AUTH_TOKEN\"}" >/dev/null

log "checking desktop viewport"
agent-browser --session "$SESSION" set viewport 1440 900 >/dev/null
agent-browser --session "$SESSION" open "$BASE_URL/ops/ui" >/dev/null
agent-browser --session "$SESSION" wait --load networkidle >/dev/null
agent-browser --session "$SESSION" screenshot "$ARTIFACT_DIR/desktop.png" >/dev/null
agent-browser --session "$SESSION" snapshot -i >"$ARTIFACT_DIR/desktop.snapshot.txt"
agent-browser --session "$SESSION" eval "$(cat <<'JS'
(() => {
  const text = document.body.innerText;
  const must = [
    "Arcwell Ops",
    "Summary",
    "Health score",
    "Radar Runs",
    "Radar run scores",
    "Knowledge Controls",
    "Schedule entity resolution",
    "Queue due entity resolution",
    "Source Cards",
    "Ops browser launch benchmark",
    "Ops browser security release",
    "Ops browser hostile <script>alert(1)</script>"
  ];
  for (const needle of must) {
    if (!text.includes(needle)) {
      throw new Error(`missing desktop text: ${needle}`);
    }
  }
  if (!document.querySelector('input[name="q"]')) throw new Error("missing search input");
  if (!document.querySelector('input[name="status"]')) throw new Error("missing status input");
  if (!document.querySelector('select[name="sort"]')) throw new Error("missing sort select");
  if (!document.querySelector('form[action="/ops/actions/knowledge/entity-resolution/schedule"]')) {
    throw new Error("missing entity-resolution schedule control");
  }
  if (!document.querySelector('form[action="/ops/actions/knowledge/entity-resolution/enqueue-due"]')) {
    throw new Error("missing entity-resolution enqueue control");
  }
  if (!document.querySelector('[aria-label="radar score distribution"]')) {
    throw new Error("missing radar score distribution bar");
  }
  if (!Array.from(document.querySelectorAll("a")).some((a) => a.href.includes("detail=radar-run"))) {
    throw new Error("missing radar-run detail link");
  }
  if (document.scripts.length !== 0) throw new Error(`unexpected script tags: ${document.scripts.length}`);
  if (document.querySelector("img[onerror]")) throw new Error("hostile image handler became DOM");
  if (document.documentElement.scrollWidth > window.innerWidth + 4) {
    throw new Error(`desktop horizontal overflow: ${document.documentElement.scrollWidth} > ${window.innerWidth}`);
  }
  return {
    title: document.title,
    width: window.innerWidth,
    sections: document.querySelectorAll("section").length,
    metrics: document.querySelectorAll(".metric").length,
    radarBars: document.querySelectorAll('[aria-label="radar score distribution"]').length
  };
})()
JS
)" >"$ARTIFACT_DIR/desktop.assertion.json"

log "checking detail navigation"
DETAIL_URL_RAW="$(agent-browser --session "$SESSION" eval '(() => Array.from(document.querySelectorAll("a")).find((a) => a.href.includes("detail=radar-run"))?.href || "")()')"
DETAIL_URL="$(printf '%s' "$DETAIL_URL_RAW" | node -e 'const fs=require("fs"); const raw=fs.readFileSync(0,"utf8"); process.stdout.write(JSON.parse(raw));')"
if [ -z "$DETAIL_URL" ]; then
  echo "BLOCKED: radar detail URL was empty" >&2
  exit 2
fi
agent-browser --session "$SESSION" open "$DETAIL_URL" >/dev/null
agent-browser --session "$SESSION" wait --load networkidle >/dev/null
agent-browser --session "$SESSION" screenshot "$ARTIFACT_DIR/detail.png" >/dev/null
agent-browser --session "$SESSION" eval "$(cat <<'JS'
(() => {
  const text = document.body.innerText;
  if (!text.includes("Detail: radar-run")) throw new Error("missing radar-run detail heading");
  if (!text.includes("score_distribution")) throw new Error("missing score_distribution in detail");
  if (!text.includes("status_counts")) throw new Error("missing status_counts in detail");
  if (document.documentElement.scrollWidth > window.innerWidth + 4) {
    throw new Error(`detail horizontal overflow: ${document.documentElement.scrollWidth} > ${window.innerWidth}`);
  }
  return { url: location.href, detail: true };
})()
JS
)" >"$ARTIFACT_DIR/detail.assertion.json"

log "checking mobile viewport"
agent-browser --session "$SESSION" set viewport 390 844 >/dev/null
agent-browser --session "$SESSION" open "$BASE_URL/ops/ui" >/dev/null
agent-browser --session "$SESSION" wait --load networkidle >/dev/null
agent-browser --session "$SESSION" screenshot "$ARTIFACT_DIR/mobile.png" >/dev/null
agent-browser --session "$SESSION" snapshot -i >"$ARTIFACT_DIR/mobile.snapshot.txt"
agent-browser --session "$SESSION" eval "$(cat <<'JS'
(() => {
  const text = document.body.innerText;
  for (const needle of ["Arcwell Ops", "Radar Runs", "Source Cards", "Ops browser"]) {
    if (!text.includes(needle)) throw new Error(`missing mobile text: ${needle}`);
  }
  if (!document.querySelector('form.ops-form')) throw new Error("missing mobile filter form");
  if (!document.querySelector('[aria-label="radar score distribution"]')) {
    throw new Error("missing mobile radar score distribution bar");
  }
  if (document.scripts.length !== 0) throw new Error(`unexpected mobile script tags: ${document.scripts.length}`);
  if (document.querySelector("img[onerror]")) throw new Error("hostile mobile image handler became DOM");
  if (document.documentElement.scrollWidth > window.innerWidth + 4) {
    throw new Error(`mobile horizontal overflow: ${document.documentElement.scrollWidth} > ${window.innerWidth}`);
  }
  return {
    title: document.title,
    width: window.innerWidth,
    sections: document.querySelectorAll("section").length,
    metrics: document.querySelectorAll(".metric").length
  };
})()
JS
)" >"$ARTIFACT_DIR/mobile.assertion.json"

agent-browser --session "$SESSION" errors >"$ARTIFACT_DIR/browser-errors.txt" || true

node - "$PROOF_ROOT" "$BASE_URL" "$ARTIFACT_DIR" <<'NODE' >"$ARTIFACT_DIR/proof-packet.json"
const fs = require("fs");
const [proofRoot, baseUrl, artifactDir] = process.argv.slice(2);
const readJson = (name) => JSON.parse(fs.readFileSync(`${artifactDir}/${name}`, "utf8"));
const proof = {
  proof_name: "ops-ui-browser-smoke",
  proof_level: "Browser-backed local HTTP proof for current /ops/ui desktop and mobile rendering",
  proof_root: proofRoot,
  base_url: baseUrl,
  arcwell_home: process.env.ARCWELL_HOME,
  artifacts: {
    desktop_screenshot: `${artifactDir}/desktop.png`,
    mobile_screenshot: `${artifactDir}/mobile.png`,
    detail_screenshot: `${artifactDir}/detail.png`,
    desktop_snapshot: `${artifactDir}/desktop.snapshot.txt`,
    mobile_snapshot: `${artifactDir}/mobile.snapshot.txt`,
    browser_errors: `${artifactDir}/browser-errors.txt`
  },
  desktop: readJson("desktop.assertion.json"),
  mobile: readJson("mobile.assertion.json"),
  detail: readJson("detail.assertion.json"),
  checked: [
    "authenticated /ops/ui page load",
    "desktop viewport has expected sections and no body horizontal overflow",
    "mobile viewport has expected sections and no body horizontal overflow",
    "filter form controls render",
    "Knowledge entity-resolution schedule/enqueue controls render",
    "radar run score distribution bar renders",
    "radar-run detail link opens and exposes score_distribution/status_counts",
    "hostile source-card HTML remains inert text"
  ],
  remaining_risk: [
    "This is browser-backed local smoke over a seeded disposable home, not a long-running production service proof.",
    "It does not prove future richer controls such as retry/requeue/cancel because those APIs are not all designed."
  ]
};
process.stdout.write(JSON.stringify(proof, null, 2));
NODE

cat "$ARTIFACT_DIR/proof-packet.json"
log "browser smoke passed"
log "proof packet: $ARTIFACT_DIR/proof-packet.json"
