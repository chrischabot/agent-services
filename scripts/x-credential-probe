#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: scripts/x-credential-probe [--self-test] [--exercise-refresh] [--write-back-rotated-tokens] [--no-watch] [--keep-home]

Proves the X credential path against a copied Arcwell home and writes a redacted
proof packet. By default it uses the copied stored bearer only; forced refresh is
guarded because OAuth refresh-token rotation can invalidate the source home.

Environment:
  X_CREDENTIAL_PROBE_SOURCE_HOME        source Arcwell home (default: /Users/chabotc/.arcwell)
  ARCWELL_X_CREDENTIAL_PROBE_DIR        proof root override
  X_CREDENTIAL_PROBE_QUERY              recent-search query (default: from:openai)
  X_CREDENTIAL_PROBE_MAX_RESULTS        recent-search cap (default: 5)
  X_CREDENTIAL_PROBE_SOURCE_HOME_IS_DISPOSABLE=1
                                       allow forced refresh without write-back
  ARCWELL_BIN                           arcwell binary override
EOF
}

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

SELF_TEST=0
EXERCISE_REFRESH=0
WRITE_BACK_ROTATED=0
RUN_WATCH=1
KEEP_HOME=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --self-test)
      SELF_TEST=1
      ;;
    --exercise-refresh)
      EXERCISE_REFRESH=1
      ;;
    --write-back-rotated-tokens)
      WRITE_BACK_ROTATED=1
      ;;
    --no-watch)
      RUN_WATCH=0
      ;;
    --keep-home)
      KEEP_HOME=1
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage
      exit 2
      ;;
  esac
  shift
done

if ! command -v node >/dev/null 2>&1; then
  echo "BLOCKED: node is required for JSON assertions." >&2
  exit 2
fi

if [ "$SELF_TEST" -eq 1 ]; then
  node <<'NODE'
function classify(text, recentStatus = 1, watchStatus = 1) {
  const lower = String(text || "").toLowerCase();
  if (/(missing|not found|absent).*(x_refresh_token|x_client_id|refresh)/.test(lower)) return "missing_refresh_material";
  if (/invalid_grant|revok|invalid refresh|expired refresh|unauthorized_client/.test(lower)) return "provider_revocation";
  if (/unsupported authentication|insufficient.*scope|scope mismatch|bookmark\.read|follows\.read|forbidden|\b403\b/.test(lower)) return "scope_mismatch";
  if (/too many requests|\b429\b|rate.?limit|quota|usagecap|tier|client.?not.?enrolled/.test(lower)) return "quota_tier_denial";
  if (recentStatus === 0 && watchStatus === 0) return "successful_current_provider_fetch";
  if (recentStatus === 0 && watchStatus === null) return "successful_current_provider_fetch";
  return "provider_network_failure";
}
const cases = [
  ["missing X_REFRESH_TOKEN and X_CLIENT_ID", 1, 1, "missing_refresh_material"],
  ["{\"error\":\"invalid_grant\",\"error_description\":\"refresh token revoked\"}", 1, 1, "provider_revocation"],
  ["403 Unsupported Authentication: bookmark.read scope required", 0, 1, "scope_mismatch"],
  ["429 Too Many Requests quota exceeded for tier", 1, 1, "quota_tier_denial"],
  ["socket hang up", 1, 1, "provider_network_failure"],
  ["", 0, 0, "successful_current_provider_fetch"],
];
for (const [text, recent, watch, expected] of cases) {
  const got = classify(text, recent, watch);
  if (got !== expected) {
    throw new Error(`classifier mismatch for ${JSON.stringify(text)}: got ${got}, expected ${expected}`);
  }
}
const leaked = "refresh_token=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa";
const redacted = leaked.replace(/[A-Za-z0-9_.=-]{32,}/g, "[REDACTED]");
if (redacted.includes("aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")) {
  throw new Error("redaction self-test failed");
}
console.log(JSON.stringify({ ok: true, cases: cases.length }));
NODE
  exit 0
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

if ! command -v sqlite3 >/dev/null 2>&1; then
  echo "BLOCKED: sqlite3 is required for copied-home metadata checks." >&2
  exit 2
fi

SOURCE_HOME="${X_CREDENTIAL_PROBE_SOURCE_HOME:-${X_USER_CONTEXT_SOURCE_HOME:-/Users/chabotc/.arcwell}}"
RUN_ID="x-credential-probe-$(date -u +%Y%m%dT%H%M%SZ)-$$"
PROOF_ROOT="${ARCWELL_X_CREDENTIAL_PROBE_DIR:-$REPO_ROOT/.arcwell-dev/proofs/$RUN_ID}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
PROBE_HOME="$PROOF_ROOT/home"
QUERY="${X_CREDENTIAL_PROBE_QUERY:-from:openai}"
MAX_RESULTS="${X_CREDENTIAL_PROBE_MAX_RESULTS:-5}"

mkdir -p "$ARTIFACT_DIR"

redact_file() {
  sed -E 's/[[:alnum:]_.=-]{32,}/[REDACTED]/g' "$1"
}

write_policy() {
  cat >"$PROBE_HOME/arcwell-policy.toml" <<'POLICY'
[[rules]]
id = "allow-x-credential-probe-provider-network"
effect = "allow"
action = "provider.network"
package = "arcwell-x"
provider = "x"
reason = "allow explicit disposable X credential probe provider calls"
priority = 20

[[rules]]
id = "allow-x-credential-probe-oauth-refresh"
effect = "allow"
action = "provider.oauth"
provider = "x"
reason = "allow explicit disposable X credential probe OAuth refresh"
priority = 20

[[rules]]
id = "allow-x-credential-probe-secret-write"
effect = "allow"
action = "secret.write"
provider = "x"
reason = "allow copied-home X credential probe token refresh writes"
priority = 20

[[rules]]
id = "allow-x-credential-probe-source-card-write"
effect = "allow"
action = "source.write"
provider = "x-import"
source = "source_card_add"
reason = "allow copied-home X credential probe source-card projections"
priority = 20
POLICY
}

write_blocked_packet() {
  local classification="$1"
  local reason="$2"
  node - "$ARTIFACT_DIR/proof-packet.json" "$classification" "$reason" "$SOURCE_HOME" "$PROBE_HOME" "$EXERCISE_REFRESH" "$WRITE_BACK_ROTATED" "$RUN_WATCH" <<'NODE'
const fs = require("fs");
const [path, classification, reason, sourceHome, probeHome, exerciseRefresh, writeBackRotated, runWatch] = process.argv.slice(2);
const packet = {
  status: "blocked",
  classification,
  reason,
  source_home: sourceHome,
  probe_home: probeHome,
  exercise_refresh: exerciseRefresh === "1",
  write_back_rotated_tokens: writeBackRotated === "1",
  watch_probe: runWatch === "1",
  artifacts: {},
};
fs.writeFileSync(path, JSON.stringify(packet, null, 2));
NODE
  cat >"$ARTIFACT_DIR/proof-packet.md" <<EOF
# X Credential Probe

Status: blocked
Classification: $classification
Reason: $reason

Proof packet: $ARTIFACT_DIR/proof-packet.json
EOF
}

if [ ! -d "$SOURCE_HOME" ]; then
  write_blocked_packet "missing_refresh_material" "source Arcwell home does not exist: $SOURCE_HOME"
  echo "BLOCKED: source Arcwell home does not exist: $SOURCE_HOME" >&2
  echo "Proof: $ARTIFACT_DIR/proof-packet.json" >&2
  exit 2
fi

mkdir -p "$PROBE_HOME"
cp -R "$SOURCE_HOME"/. "$PROBE_HOME"/
write_policy

run_arcwell() {
  env -u X_BEARER_TOKEN -u TWITTER_BEARER_TOKEN ARCWELL_HOME="$PROBE_HOME" "$ARCWELL_BIN" "$@"
}

run_arcwell secrets health >"$ARTIFACT_DIR/secrets-health-before.json" 2>"$ARTIFACT_DIR/secrets-health-before.err" || true
run_arcwell secrets list-values >"$ARTIFACT_DIR/secrets-list-before.json" 2>"$ARTIFACT_DIR/secrets-list-before.err" || true

node - "$ARTIFACT_DIR/secrets-health-before.json" "$ARTIFACT_DIR/secrets-list-before.json" >"$ARTIFACT_DIR/preflight.json" <<'NODE'
const fs = require("fs");
function readJson(path, fallback) {
  try { return JSON.parse(fs.readFileSync(path, "utf8")); } catch { return fallback; }
}
const health = readJson(process.argv[2], []);
const values = readJson(process.argv[3], []);
function healthItem(name) {
  return Array.isArray(health) ? health.find((item) => item.name === name) : null;
}
function valueItem(name) {
  return Array.isArray(values) ? values.find((item) => item.name === name) : null;
}
function present(name) {
  const h = healthItem(name);
  const v = valueItem(name);
  return Boolean((h && h.present === true) || v);
}
function expired(name) {
  const h = healthItem(name);
  const v = valueItem(name);
  const status = String((h && h.status) || (v && v.status) || "").toLowerCase();
  if (status === "expired") return true;
  const expiresAt = (h && h.expires_at) || (v && v.expires_at);
  if (!expiresAt) return false;
  const ms = Date.parse(expiresAt);
  return Number.isFinite(ms) && ms <= Date.now();
}
const preflight = {
  has_bearer: present("X_BEARER_TOKEN"),
  bearer_expired: expired("X_BEARER_TOKEN"),
  has_refresh: present("X_REFRESH_TOKEN"),
  refresh_expired: expired("X_REFRESH_TOKEN"),
  has_client_id: present("X_CLIENT_ID"),
  has_client_secret: present("X_CLIENT_SECRET"),
};
console.log(JSON.stringify(preflight, null, 2));
NODE

eval "$(node - "$ARTIFACT_DIR/preflight.json" <<'NODE'
const fs = require("fs");
const p = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
for (const [key, value] of Object.entries({
  HAS_BEARER: p.has_bearer,
  BEARER_EXPIRED: p.bearer_expired,
  HAS_REFRESH: p.has_refresh,
  REFRESH_EXPIRED: p.refresh_expired,
  HAS_CLIENT_ID: p.has_client_id,
})) {
  console.log(`${key}=${value ? 1 : 0}`);
}
NODE
)"

if [ "$EXERCISE_REFRESH" -eq 0 ] && { [ "$HAS_BEARER" -eq 0 ] || [ "$BEARER_EXPIRED" -eq 1 ]; }; then
  write_blocked_packet "missing_refresh_material" "stored bearer is missing or expired; rerun with --exercise-refresh after acknowledging rotation safety"
  echo "BLOCKED: stored bearer is missing or expired; refusing accidental refresh in safe mode." >&2
  echo "Proof: $ARTIFACT_DIR/proof-packet.json" >&2
  exit 2
fi

if [ "$EXERCISE_REFRESH" -eq 1 ]; then
  if [ "$HAS_REFRESH" -eq 0 ] || [ "$HAS_CLIENT_ID" -eq 0 ] || [ "$REFRESH_EXPIRED" -eq 1 ]; then
    write_blocked_packet "missing_refresh_material" "forced refresh requested but X_REFRESH_TOKEN/X_CLIENT_ID material is missing or expired"
    echo "BLOCKED: forced refresh requested but refresh material is missing or expired." >&2
    echo "Proof: $ARTIFACT_DIR/proof-packet.json" >&2
    exit 2
  fi
  if [ "${X_CREDENTIAL_PROBE_SOURCE_HOME_IS_DISPOSABLE:-0}" != "1" ] && [ "$WRITE_BACK_ROTATED" -ne 1 ]; then
    write_blocked_packet "refresh_rotation_guard" "forced copied-home refresh can rotate the server-side refresh token; set X_CREDENTIAL_PROBE_SOURCE_HOME_IS_DISPOSABLE=1 or pass --write-back-rotated-tokens"
    echo "BLOCKED: forced refresh could invalidate the real source refresh token." >&2
    echo "Set X_CREDENTIAL_PROBE_SOURCE_HOME_IS_DISPOSABLE=1 for a disposable credential home, or pass --write-back-rotated-tokens." >&2
    echo "Proof: $ARTIFACT_DIR/proof-packet.json" >&2
    exit 2
  fi
  sqlite3 "$PROBE_HOME/arcwell.sqlite3" \
    "UPDATE secret_values SET expires_at = '2000-01-01T00:00:00Z' WHERE name = 'X_BEARER_TOKEN';"
  echo "Forced copied-home X_BEARER_TOKEN expiry to exercise stored-token auto-refresh." >"$ARTIFACT_DIR/forced-expiry.txt"
fi

set +e
run_arcwell x recent-search "$QUERY" --max-results "$MAX_RESULTS" >"$ARTIFACT_DIR/recent-search.json" 2>"$ARTIFACT_DIR/recent-search.err"
RECENT_STATUS=$?
set -e

WATCH_STATUS=0
if [ "$RECENT_STATUS" -eq 0 ] && [ "$RUN_WATCH" -eq 1 ]; then
  set +e
  run_arcwell x rebuild-definitive-watch-sources \
    --bookmark-days 92 \
    --max-bookmarks "${X_CREDENTIAL_PROBE_MAX_BOOKMARKS:-1}" \
    --max-recent-follows "${X_CREDENTIAL_PROBE_MAX_RECENT_FOLLOWS:-1}" \
    >"$ARTIFACT_DIR/watch-rebuild.json" 2>"$ARTIFACT_DIR/watch-rebuild.err"
  WATCH_STATUS=$?
  set -e
else
  WATCH_STATUS=99
fi

run_arcwell secrets health >"$ARTIFACT_DIR/secrets-health-after.json" 2>"$ARTIFACT_DIR/secrets-health-after.err" || true
run_arcwell secrets list-values >"$ARTIFACT_DIR/secrets-list-after.json" 2>"$ARTIFACT_DIR/secrets-list-after.err" || true
run_arcwell x stats >"$ARTIFACT_DIR/x-stats.json" 2>"$ARTIFACT_DIR/x-stats.err" || true
run_arcwell ops >"$ARTIFACT_DIR/ops.json" 2>"$ARTIFACT_DIR/ops.err" || true

if [ "$WRITE_BACK_ROTATED" -eq 1 ]; then
  SOURCE_DB="$SOURCE_HOME/arcwell.sqlite3"
  PROBE_DB="$PROBE_HOME/arcwell.sqlite3"
  if [ -f "$SOURCE_DB" ] && [ -f "$PROBE_DB" ]; then
    sqlite3 "$SOURCE_DB" <<SQL
ATTACH '$PROBE_DB' AS probe;
BEGIN IMMEDIATE;
UPDATE secret_values
SET value = (SELECT value FROM probe.secret_values WHERE name = 'X_BEARER_TOKEN'),
    scope = (SELECT scope FROM probe.secret_values WHERE name = 'X_BEARER_TOKEN'),
    provider = (SELECT provider FROM probe.secret_values WHERE name = 'X_BEARER_TOKEN'),
    expires_at = (SELECT expires_at FROM probe.secret_values WHERE name = 'X_BEARER_TOKEN'),
    updated_at = (SELECT updated_at FROM probe.secret_values WHERE name = 'X_BEARER_TOKEN')
WHERE name = 'X_BEARER_TOKEN'
  AND EXISTS (SELECT 1 FROM probe.secret_values WHERE name = 'X_BEARER_TOKEN');
INSERT INTO secret_values (name, value, scope, provider, expires_at, updated_at)
SELECT name, value, scope, provider, expires_at, updated_at
FROM probe.secret_values
WHERE name = 'X_BEARER_TOKEN'
  AND NOT EXISTS (SELECT 1 FROM main.secret_values WHERE name = 'X_BEARER_TOKEN');
UPDATE secret_values
SET value = (SELECT value FROM probe.secret_values WHERE name = 'X_REFRESH_TOKEN'),
    scope = (SELECT scope FROM probe.secret_values WHERE name = 'X_REFRESH_TOKEN'),
    provider = (SELECT provider FROM probe.secret_values WHERE name = 'X_REFRESH_TOKEN'),
    expires_at = (SELECT expires_at FROM probe.secret_values WHERE name = 'X_REFRESH_TOKEN'),
    updated_at = (SELECT updated_at FROM probe.secret_values WHERE name = 'X_REFRESH_TOKEN')
WHERE name = 'X_REFRESH_TOKEN'
  AND EXISTS (SELECT 1 FROM probe.secret_values WHERE name = 'X_REFRESH_TOKEN');
INSERT INTO secret_values (name, value, scope, provider, expires_at, updated_at)
SELECT name, value, scope, provider, expires_at, updated_at
FROM probe.secret_values
WHERE name = 'X_REFRESH_TOKEN'
  AND NOT EXISTS (SELECT 1 FROM main.secret_values WHERE name = 'X_REFRESH_TOKEN');
COMMIT;
SQL
    echo "Rotated copied-home X bearer/refresh metadata was written back to source home without printing values." >"$ARTIFACT_DIR/write-back.txt"
  fi
fi

node - "$ARTIFACT_DIR" "$SOURCE_HOME" "$PROBE_HOME" "$QUERY" "$MAX_RESULTS" "$EXERCISE_REFRESH" "$WRITE_BACK_ROTATED" "$RUN_WATCH" "$RECENT_STATUS" "$WATCH_STATUS" <<'NODE'
const fs = require("fs");
const path = require("path");
const [artifactDir, sourceHome, probeHome, query, maxResults, exerciseRefresh, writeBackRotated, runWatch, recentStatusRaw, watchStatusRaw] = process.argv.slice(2);
const recentStatus = Number(recentStatusRaw);
const watchStatus = Number(watchStatusRaw);
function read(file) {
  try { return fs.readFileSync(path.join(artifactDir, file), "utf8"); } catch { return ""; }
}
function json(file, fallback) {
  try { return JSON.parse(read(file)); } catch { return fallback; }
}
function classify(text) {
  const lower = String(text || "").toLowerCase();
  if (/(missing|not found|absent).*(x_refresh_token|x_client_id|refresh)/.test(lower)) return "missing_refresh_material";
  if (/invalid_grant|revok|invalid refresh|expired refresh|unauthorized_client/.test(lower)) return "provider_revocation";
  if (/unsupported authentication|insufficient.*scope|scope mismatch|bookmark\.read|follows\.read|forbidden|\b403\b/.test(lower)) return "scope_mismatch";
  if (/too many requests|\b429\b|rate.?limit|quota|usagecap|tier|client.?not.?enrolled/.test(lower)) return "quota_tier_denial";
  if (recentStatus === 0 && (runWatch !== "1" || watchStatus === 0)) return "successful_current_provider_fetch";
  if (recentStatus === 0 && watchStatus !== 0) return classify(read("watch-rebuild.err") || read("watch-rebuild.json"));
  return "provider_network_failure";
}
function listItem(rows, name) {
  return Array.isArray(rows) ? rows.find((row) => row.name === name) : null;
}
const before = json("secrets-list-before.json", []);
const after = json("secrets-list-after.json", []);
const beforeBearer = listItem(before, "X_BEARER_TOKEN");
const afterBearer = listItem(after, "X_BEARER_TOKEN");
const beforeRefresh = listItem(before, "X_REFRESH_TOKEN");
const afterRefresh = listItem(after, "X_REFRESH_TOKEN");
const combinedErrors = [
  read("recent-search.err"),
  read("watch-rebuild.err"),
  read("secrets-health-before.err"),
  read("secrets-health-after.err"),
  read("x-stats.err"),
  read("ops.err"),
].join("\n");
const classification = classify(combinedErrors || read("recent-search.json") || read("watch-rebuild.json"));
const artifactNames = fs.readdirSync(artifactDir).filter((name) => name !== "proof-packet.json").sort();
const secretEnvValues = [process.env.X_BEARER_TOKEN, process.env.TWITTER_BEARER_TOKEN, process.env.X_REFRESH_TOKEN].filter(Boolean);
const leaks = [];
for (const name of artifactNames) {
  const fullPath = path.join(artifactDir, name);
  if (!fs.statSync(fullPath).isFile()) continue;
  const text = fs.readFileSync(fullPath, "utf8");
  for (const token of secretEnvValues) {
    if (token.length >= 8 && text.includes(token)) leaks.push({ artifact: name, token: token.slice(0, 4) + "..." });
  }
}
const refreshRotated = Boolean(beforeRefresh && afterRefresh && beforeRefresh.updated_at !== afterRefresh.updated_at);
const bearerUpdated = Boolean(beforeBearer && afterBearer && (
  beforeBearer.updated_at !== afterBearer.updated_at || beforeBearer.expires_at !== afterBearer.expires_at
));
const status = classification === "successful_current_provider_fetch" && leaks.length === 0 ? "passed" : "blocked";
const packet = {
  status,
  classification,
  query,
  max_results: Number(maxResults),
  source_home: sourceHome,
  probe_home: probeHome,
  exercise_refresh: exerciseRefresh === "1",
  write_back_rotated_tokens: writeBackRotated === "1",
  watch_probe: runWatch === "1",
  stages: {
    recent_search_exit: recentStatus,
    watch_rebuild_exit: runWatch === "1" ? watchStatus : null,
  },
  refresh: {
    bearer_forced_expired: exerciseRefresh === "1",
    bearer_updated_after_probe: bearerUpdated,
    refresh_token_rotated_after_probe: refreshRotated,
  },
  redaction: {
    checked_env_token_values: secretEnvValues.length,
    leaks,
  },
  state: {
    preflight: json("preflight.json", null),
    x_stats: json("x-stats.json", null),
    ops_source_health: (json("ops.json", {}).source_health || []).filter((row) => String(row.key || row.source || "").toLowerCase().includes("x")).slice(0, 25),
  },
  artifacts: Object.fromEntries(artifactNames.map((name) => [name, path.join(artifactDir, name)])),
};
fs.writeFileSync(path.join(artifactDir, "proof-packet.json"), JSON.stringify(packet, null, 2));
fs.writeFileSync(path.join(artifactDir, "proof-packet.md"), [
  "# X Credential Probe",
  "",
  `Status: ${packet.status}`,
  `Classification: ${packet.classification}`,
  `Recent search exit: ${recentStatus}`,
  `Watch rebuild exit: ${packet.stages.watch_rebuild_exit === null ? "not run" : packet.stages.watch_rebuild_exit}`,
  `Bearer updated after probe: ${packet.refresh.bearer_updated_after_probe}`,
  `Refresh token rotated after probe: ${packet.refresh.refresh_token_rotated_after_probe}`,
  `Redaction leaks: ${leaks.length}`,
  "",
  "Artifacts:",
  ...artifactNames.map((name) => `- ${name}`),
  "",
].join("\n"));
NODE

CLASSIFICATION="$(node -e 'const fs=require("fs");const p=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));console.log(p.classification)' "$ARTIFACT_DIR/proof-packet.json")"
STATUS="$(node -e 'const fs=require("fs");const p=JSON.parse(fs.readFileSync(process.argv[1],"utf8"));console.log(p.status)' "$ARTIFACT_DIR/proof-packet.json")"

if [ "$STATUS" != "passed" ]; then
  echo "BLOCKED: X credential probe classified result as $CLASSIFICATION." >&2
  for file in recent-search.err watch-rebuild.err; do
    if [ -s "$ARTIFACT_DIR/$file" ]; then
      echo "--- redacted $file ---" >&2
      redact_file "$ARTIFACT_DIR/$file" >&2
    fi
  done
  echo "Proof: $ARTIFACT_DIR/proof-packet.json" >&2
  exit 2
fi

echo "X credential probe passed: $ARTIFACT_DIR/proof-packet.json"
if [ "$KEEP_HOME" -ne 1 ]; then
  echo "Copied proof home retained for inspection: $PROBE_HOME"
else
  echo "Copied proof home retained by --keep-home: $PROBE_HOME"
fi
