    metadata: real,
  },
];
const metadata = {
  generated_at: new Date().toISOString(),
  schema_version: schemaVersion,
  source_artifact: path.relative(process.cwd(), sourceArtifact),
  before_counts: beforeCounts,
  after_counts: afterCounts,
  watch_source_counts_before: watchBefore,
  watch_source_counts_after: watchAfter,
  private_backup: {
    path: path.relative(proofRoot, privateBackup),
    sha256: sha256(privateBackup),
    bytes: fs.statSync(privateBackup).size,
    artifact_listed: false,
    reason: "SQLite backup is intentionally not listed as a proof artifact to avoid proof-verifier content scans over private production data.",
  },
