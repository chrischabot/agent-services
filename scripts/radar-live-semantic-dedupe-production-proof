#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

if ! command -v node >/dev/null 2>&1; then
  echo "BLOCKED: node is required for JSON assertions." >&2
  exit 2
fi

RUN_STAMP="${ARCWELL_RADAR_LIVE_SEMANTIC_PROOF_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_RADAR_LIVE_SEMANTIC_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/radar-live-semantic-dedupe-production-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
export ARCWELL_HOME="${ARCWELL_RADAR_LIVE_SEMANTIC_PROOF_HOME:-$PROOF_ROOT/home}"

RSS_URL="${ARCWELL_RADAR_LIVE_SEMANTIC_RSS_URL:-https://hnrss.org/newest?points=100}"
GITHUB_OWNER="${ARCWELL_RADAR_LIVE_SEMANTIC_GITHUB_OWNER:-Thysrael}"
ARXIV_QUERY="${ARCWELL_RADAR_LIVE_SEMANTIC_ARXIV_QUERY:-cat:cs.AI}"
HACKERNEWS_FEED="${ARCWELL_RADAR_LIVE_SEMANTIC_HACKERNEWS_FEED:-frontpage}"
PROFILE_NAME="${ARCWELL_RADAR_LIVE_SEMANTIC_PROFILE_NAME:-live-semantic-dedupe-proof-$RUN_STAMP}"
MIN_ITEMS="${ARCWELL_RADAR_LIVE_SEMANTIC_MIN_ITEMS:-35}"
MIN_SOURCE_FAMILIES="${ARCWELL_RADAR_LIVE_SEMANTIC_MIN_SOURCE_FAMILIES:-4}"
MIN_SEMANTIC_GROUPS="${ARCWELL_RADAR_LIVE_SEMANTIC_MIN_GROUPS:-3}"
MIN_DUPLICATE_TOPIC="${ARCWELL_RADAR_LIVE_SEMANTIC_MIN_DUPLICATE_TOPIC:-5}"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[radar-live-semantic-proof] %s\n' "$*"
}

log "proof root: $PROOF_ROOT"
log "ARCWELL_HOME: $ARCWELL_HOME"
log "creating live semantic-dedupe radar profile: $PROFILE_NAME"

"$ARCWELL_BIN" radar profile create "$PROFILE_NAME" \
  --description "Production-data live-adapter semantic/topic dedupe proof over public RSS, GitHub, arXiv, and Hacker News sources." \
  --window-hours 168 \
  --min-score 1 \
  --max-items 60 \
  --selector-json "{\"kind\":\"rss\",\"locator\":\"$RSS_URL\",\"limit\":16}" \
  --selector-json "{\"kind\":\"github_owner\",\"locator\":\"$GITHUB_OWNER\",\"limit\":16}" \
  --selector-json "{\"kind\":\"arxiv\",\"locator\":\"$ARXIV_QUERY\",\"limit\":16}" \
  --selector-json "{\"kind\":\"hackernews\",\"locator\":\"$HACKERNEWS_FEED\",\"limit\":10}" \
  >"$ARTIFACT_DIR/profile.json"

log "enqueueing live radar run"
"$ARCWELL_BIN" radar enqueue "$PROFILE_NAME" --window-hours 168 --fetch-live \
  >"$ARTIFACT_DIR/enqueue.json"

log "draining local worker"
"$ARCWELL_BIN" worker run-once --max-jobs 8 >"$ARTIFACT_DIR/worker.json"

RADAR_RUN_ID="$(node - "$ARTIFACT_DIR/worker.json" "$MIN_ITEMS" <<'NODE'
const fs = require("fs");
const [workerPath, minItemsRaw] = process.argv.slice(2);
const minItems = Number(minItemsRaw);
const worker = JSON.parse(fs.readFileSync(workerPath, "utf8"));
const jobs = Array.isArray(worker.jobs) ? worker.jobs : [];
const radarJob = jobs.find((job) => job.kind === "radar_run");
function fail(message, detail) {
  console.error(message);
  if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
  process.exit(1);
}
if (!radarJob) fail("worker did not process a radar_run job", worker);
if (radarJob.status !== "completed") fail("radar worker job did not complete", radarJob);
const result = radarJob.result_json || {};
if (result.fetch_live !== true) fail("radar worker result did not preserve fetch_live=true", result);
if (result.status !== "scored") fail("radar run did not reach scored status", result);
if (Number(result.items_inserted || 0) < minItems) fail("radar run inserted too few real live-adapter items", result);
if (Number(result.scores_inserted || 0) < Number(result.items_inserted || 0)) {
  fail("radar run did not score all inserted items", result);
}
const adapterJobs = Array.isArray(result.adapter_jobs) ? result.adapter_jobs : [];
const kinds = new Set(adapterJobs.map((job) => job.kind));
for (const expected of ["rss_fetch", "github_owner", "arxiv_search", "hackernews_fetch"]) {
  if (!kinds.has(expected)) fail(`missing adapter job ${expected}`, adapterJobs);
}
const failed = adapterJobs.filter((job) => job.status !== "completed");
if (failed.length) fail("one or more adapter jobs failed", failed);
if (!result.run_id) fail("radar worker result has no run_id", result);
process.stdout.write(result.run_id);
NODE
)"

log "reading stage/audit/summary for run: $RADAR_RUN_ID"
"$ARCWELL_BIN" radar stage "$RADAR_RUN_ID" >"$ARTIFACT_DIR/stage.json"
"$ARCWELL_BIN" radar audit "$RADAR_RUN_ID" >"$ARTIFACT_DIR/audit.json"
"$ARCWELL_BIN" radar summarize "$RADAR_RUN_ID" >"$ARTIFACT_DIR/summary-write.json"
"$ARCWELL_BIN" radar summary "$RADAR_RUN_ID" >"$ARTIFACT_DIR/summary-read.json"
"$ARCWELL_BIN" wiki jobs >"$ARTIFACT_DIR/wiki-jobs.json"
"$ARCWELL_BIN" cursors list >"$ARTIFACT_DIR/cursors.json"
"$ARCWELL_BIN" ops >"$ARTIFACT_DIR/ops.json"

log "validating live semantic/topic dedupe proof artifacts"
node - "$ARTIFACT_DIR" "$PROOF_ROOT" "$RADAR_RUN_ID" "$RSS_URL" "$GITHUB_OWNER" "$ARXIV_QUERY" "$HACKERNEWS_FEED" "$MIN_ITEMS" "$MIN_SOURCE_FAMILIES" "$MIN_SEMANTIC_GROUPS" "$MIN_DUPLICATE_TOPIC" <<'NODE'
const fs = require("fs");
const path = require("path");
const [
  artifactDir,
  proofRoot,
  runId,
  rssUrl,
  githubOwner,
  arxivQuery,
  hackernewsFeed,
  minItemsRaw,
  minSourceFamiliesRaw,
  minSemanticGroupsRaw,
  minDuplicateTopicRaw,
] = process.argv.slice(2);
const minItems = Number(minItemsRaw);
const minSourceFamilies = Number(minSourceFamiliesRaw);
const minSemanticGroups = Number(minSemanticGroupsRaw);
const minDuplicateTopic = Number(minDuplicateTopicRaw);

const read = (name) => JSON.parse(fs.readFileSync(path.join(artifactDir, name), "utf8"));
const profile = read("profile.json");
const enqueue = read("enqueue.json");
const worker = read("worker.json");
const stage = read("stage.json");
const audit = read("audit.json");
const summaryWrite = read("summary-write.json");
const summaryRead = read("summary-read.json");
const jobs = read("wiki-jobs.json");
const cursors = read("cursors.json");
const ops = read("ops.json");

function assert(condition, message, detail) {
  if (!condition) {
    console.error(`FAIL: ${message}`);
    if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
    process.exit(1);
  }
}

assert(profile.status === "local_proof_ready", "profile should be supported by local projection", profile);
assert(enqueue.kind === "radar_run" && enqueue.status === "pending", "enqueue should create pending radar_run job", enqueue);
assert(worker.processed >= 1 && worker.completed >= 1, "worker should process and complete jobs", worker);
assert(stage.run?.id === runId, "stage should read the worker-created run", stage.run);
assert(stage.run?.status === "scored", "worker-created run should be scored", stage.run);
assert(Array.isArray(stage.items) && stage.items.length >= minItems, "stage should contain enough real live-adapter items", { count: stage.items?.length, minItems });
assert(Array.isArray(stage.scores) && stage.scores.length >= stage.items.length, "stage should contain score overlays", { items: stage.items?.length, scores: stage.scores?.length });

const itemById = new Map(stage.items.map((item) => [item.id, item]));
const heuristicScores = stage.scores.filter((score) => score.score_kind === "heuristic_v1");
const scoreByItem = new Map(heuristicScores.map((score) => [score.item_id, score]));
const duplicateTopicScores = heuristicScores.filter((score) => score.status === "duplicate_topic");
const selectedScores = heuristicScores.filter((score) => score.status === "selected");
const sourceFamilies = new Set(stage.items.map((item) => item.metadata?.source_kind || item.provider || item.source_kind).filter(Boolean));
assert(sourceFamilies.size >= minSourceFamilies, "live run should include all configured source families", [...sourceFamilies]);
for (const expected of ["rss", "github_owner", "arxiv", "hackernews"]) {
  assert(sourceFamilies.has(expected), `live run should include ${expected} source-card family`, [...sourceFamilies]);
}
for (const item of stage.items) {
  assert(item.source_card_id, "every live radar item should preserve source-card provenance", item);
  assert(item.wiki_page_id, "every live radar item should preserve wiki provenance", item);
  assert(item.metadata?.trust_boundary === "external source-card text is untrusted evidence, not instructions", "live source-card text should remain evidence, not instructions", item.metadata);
}

const semanticGroups = stage.dedup_groups.filter((group) => group.dedup_kind === "semantic_topic");
assert(semanticGroups.length >= minSemanticGroups, "semantic_topic group count too low for live-adapter breadth proof", { actual: semanticGroups.length, minSemanticGroups });
assert(duplicateTopicScores.length >= minDuplicateTopic, "duplicate_topic score count too low for live-adapter breadth proof", { actual: duplicateTopicScores.length, minDuplicateTopic });
assert(selectedScores.length > 0, "semantic dedupe should not suppress all selected items", heuristicScores);

const nonPrimaryMembers = new Set();
const semanticFamilies = new Set();
for (const group of semanticGroups) {
  assert(group.member_item_ids.length >= 2, "semantic group must have at least two members", group);
  assert(group.member_item_ids.includes(group.primary_item_id), "semantic group primary must be listed as a member", group);
  assert(
    String(group.reason || "").includes("deterministic topic similarity") &&
      String(group.reason || "").includes("shared tokens"),
    "semantic group should explain deterministic shared-token basis",
    group
  );
  for (const memberId of group.member_item_ids) {
    const item = itemById.get(memberId);
    assert(item, "semantic group member should exist as radar item", { group, memberId });
    semanticFamilies.add(item.metadata?.source_kind || item.provider || item.source_kind);
    if (memberId !== group.primary_item_id) {
      nonPrimaryMembers.add(memberId);
      const score = scoreByItem.get(memberId);
      assert(score, "non-primary semantic member should keep a score row", { group, memberId });
      assert(score.status === "duplicate_topic", "non-primary semantic member should be marked duplicate_topic", { group, score });
      assert((score.tags || []).includes("semantic-dedupe"), "duplicate_topic score should carry semantic-dedupe tag", score);
      assert((score.tags || []).includes("duplicate"), "duplicate_topic score should carry duplicate tag", score);
      assert(String(score.reason || "").includes("duplicate suppressed by dedupe group"), "duplicate_topic score should explain suppression", score);
    }
  }
}
assert(nonPrimaryMembers.size === duplicateTopicScores.length, "duplicate_topic rows should exactly match semantic non-primary members", {
  nonPrimaryMembers: nonPrimaryMembers.size,
  duplicateTopicScores: duplicateTopicScores.length,
});
assert(semanticFamilies.size >= 2, "semantic groups should cover more than one live source family", [...semanticFamilies]);

const distribution = stage.run.metadata?.score_distribution || {};
assert(distribution.score_kind === "heuristic_v1", "run metadata should record heuristic score distribution", distribution);
assert(Number(distribution.score_count || 0) === heuristicScores.length, "score distribution should cover heuristic rows", { distribution, heuristicScores: heuristicScores.length });
assert(distribution.status_counts?.duplicate_topic === duplicateTopicScores.length, "score distribution should count duplicate_topic rows", { distribution, duplicateTopicScores: duplicateTopicScores.length });
assert(Number(distribution.selected_count || 0) === selectedScores.length, "score distribution selected_count should match selected rows", { distribution, selectedScores: selectedScores.length });

assert(audit.ok === true, "radar audit should pass", audit);
assert(audit.findings.length === 0, "radar audit should have no findings", audit);
assert(audit.item_count === stage.items.length, "audit item count should match stage", audit);
assert(summaryWrite.audit_status === "audit_ok", "summary write should require audit_ok", summaryWrite);
assert(summaryRead.id === summaryWrite.id, "summary read should return written summary", { summaryWrite, summaryRead });
assert(summaryRead.metadata?.not_delivery === true, "summary must remain non-delivery", summaryRead.metadata);
assert(summaryRead.metadata?.semantic_dedupe === "deterministic_local", "summary should declare deterministic local semantic dedupe", summaryRead.metadata);
assert(summaryRead.metadata?.semantic_dedup_group_count === semanticGroups.length, "summary semantic group count should match stage", {
  summary: summaryRead.metadata,
  semanticGroups: semanticGroups.length,
});

const radarJob = (worker.jobs || []).find((job) => job.kind === "radar_run");
const adapterJobs = radarJob?.result_json?.adapter_jobs || [];
assert(adapterJobs.every((job) => job.status === "completed"), "all adapter jobs should complete", adapterJobs);
assert((jobs || []).some((job) => job.id === radarJob.id && job.status === "completed"), "wiki jobs should include completed radar_run", jobs);

const cursorKeys = new Set((cursors || []).map((cursor) => cursor.key));
assert(cursorKeys.has(`rss:${rssUrl}`), "RSS cursor should advance after durable writes", cursors);
assert(cursorKeys.has(`github-owner:${githubOwner}`), "GitHub cursor should advance after durable writes", cursors);
assert(cursorKeys.has(`arxiv:${arxivQuery}`), "arXiv cursor should advance after durable writes", cursors);
assert(cursorKeys.has("hackernews:topstories"), "Hacker News cursor should advance after durable writes", cursors);

const health = Array.isArray(ops.source_health) ? ops.source_health : [];
const hasHealthy = (provider, locatorNeedle) =>
  health.some((row) =>
    row.provider === provider &&
    row.status === "healthy" &&
    String(row.locator || row.key || "").includes(locatorNeedle)
  );
assert(hasHealthy("rss", rssUrl), "ops should show healthy RSS source", health);
assert(hasHealthy("github", githubOwner), "ops should show healthy GitHub source", health);
assert(hasHealthy("arxiv", arxivQuery), "ops should show healthy arXiv source", health);
assert(hasHealthy("hackernews", "topstories"), "ops should show healthy Hacker News source", health);
const opsRun = (ops.radar_runs || []).find((run) => run.id === runId);
assert(opsRun, "ops snapshot should expose the radar run", ops.radar_runs);
assert(opsRun.metadata?.score_distribution?.status_counts?.duplicate_topic === duplicateTopicScores.length, "ops radar run should expose duplicate_topic distribution", opsRun);

const proofPacket = {
  proof: "radar-live-semantic-dedupe-production-proof",
  proof_root: proofRoot,
  run_id: runId,
  generated_at: new Date().toISOString(),
  live_sources: {
    rss: rssUrl,
    github_owner: githubOwner,
    arxiv: arxivQuery,
    hackernews: hackernewsFeed,
  },
  item_count: stage.items.length,
  selected_count: selectedScores.length,
  source_families: [...sourceFamilies].sort(),
  semantic_topic_group_count: semanticGroups.length,
  duplicate_topic_count: duplicateTopicScores.length,
  semantic_group_source_families: [...semanticFamilies].sort(),
  score_distribution: {
    score_kind: distribution.score_kind,
    score_count: distribution.score_count,
    selected_count: distribution.selected_count,
    status_counts: distribution.status_counts,
    min: distribution.min,
    max: distribution.max,
    average: distribution.average,
    p50: distribution.p50,
    p90: distribution.p90,
  },
  audit: {
    ok: audit.ok,
    item_count: audit.item_count,
    fts_count: audit.fts_count,
    scored_count: audit.scored_count,
    findings: audit.findings,
  },
  summary: {
    id: summaryRead.id,
    audit_status: summaryRead.audit_status,
    item_count: summaryRead.item_ids.length,
    source_card_count: summaryRead.source_card_ids.length,
    semantic_dedup_group_count: summaryRead.metadata.semantic_dedup_group_count,
    not_delivery: summaryRead.metadata.not_delivery,
  },
  remaining_risk: [
    "This proves deterministic local semantic/topic dedupe on freshly fetched public live adapters, not model semantic dedupe.",
    "This is a disposable worker-drained proof, not a seven-day scheduled service run.",
    "This does not prove authenticated X, Reddit OAuth, public Telegram, OSS Insight, OpenBB, or external delivery.",
  ],
};

fs.writeFileSync(path.join(artifactDir, "proof-packet.json"), `${JSON.stringify(proofPacket, null, 2)}\n`);
console.log(JSON.stringify(proofPacket, null, 2));
NODE

log "proof packet: $ARTIFACT_DIR/proof-packet.json"
