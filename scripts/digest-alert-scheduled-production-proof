#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ARCWELL_BIN="${ARCWELL_BIN:-$REPO_ROOT/target/debug/arcwell}"
if [ ! -x "$ARCWELL_BIN" ]; then
  ARCWELL_BIN="$(command -v arcwell || true)"
fi

if [ -z "${ARCWELL_BIN:-}" ] || [ ! -x "$ARCWELL_BIN" ]; then
  echo "BLOCKED: arcwell binary not found. Run: cargo build -p arcwell" >&2
  exit 2
fi

for required in node rsync; do
  if ! command -v "$required" >/dev/null 2>&1; then
    echo "BLOCKED: $required is required for this proof." >&2
    exit 2
  fi
done

RUN_STAMP="${ARCWELL_DIGEST_ALERT_PROOF_RUN_ID:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
PROOF_ROOT="${ARCWELL_DIGEST_ALERT_PROOF_DIR:-$REPO_ROOT/.arcwell-dev/proofs/digest-alert-scheduled-production-proof-$RUN_STAMP}"
ARTIFACT_DIR="$PROOF_ROOT/artifacts"
SOURCE_HOME="${ARCWELL_DIGEST_ALERT_SOURCE_HOME:-${ARCWELL_HOME:-$HOME/.arcwell}}"
export ARCWELL_HOME="${ARCWELL_DIGEST_ALERT_PROOF_HOME:-$PROOF_ROOT/home}"
QUERY="${ARCWELL_DIGEST_ALERT_QUERY:-agent}"
RECIPIENT="${ARCWELL_DIGEST_ALERT_EMAIL_TO:-digest-proof@example.com}"
FROM="${ARCWELL_DIGEST_ALERT_EMAIL_FROM:-agent@example.com}"

mkdir -p "$ARTIFACT_DIR" "$ARCWELL_HOME"

log() {
  printf '[digest-alert-proof] %s\n' "$*"
}

fail() {
  printf '[digest-alert-proof] BLOCKED: %s\n' "$*" >&2
  exit 2
}

if [ ! -d "$SOURCE_HOME" ]; then
  fail "source Arcwell home not found: $SOURCE_HOME"
fi

log "proof root: $PROOF_ROOT"
log "copying source home into disposable proof home"
rsync -a --exclude 'backups/' --exclude 'proofs/' "$SOURCE_HOME"/ "$ARCWELL_HOME"/ >/dev/null
if [ -f "$ARCWELL_HOME/arcwell.sqlite3" ]; then
  log "clearing copied operational queues while preserving source cards/wiki evidence"
  sqlite3 "$ARCWELL_HOME/arcwell.sqlite3" <<'SQL'
PRAGMA foreign_keys = OFF;
DELETE FROM wiki_jobs;
DELETE FROM channel_delivery_attempts;
DELETE FROM channel_messages;
DELETE FROM digest_alert_ticks;
DELETE FROM digest_alert_schedules;
DELETE FROM digest_deliveries;
DELETE FROM digest_candidates;
DELETE FROM policy_decisions;
DELETE FROM watch_sources;
PRAGMA foreign_keys = ON;
SQL
fi

MOCK_BASE_FILE="$ARTIFACT_DIR/email-api-base.txt"
MOCK_LOG_FILE="$ARTIFACT_DIR/email-provider-requests.jsonl"
node - "$MOCK_BASE_FILE" "$MOCK_LOG_FILE" <<'NODE' &
const fs = require("fs");
const http = require("http");
const [basePath, logPath] = process.argv.slice(2);

const server = http.createServer((req, res) => {
  const chunks = [];
  req.on("data", (chunk) => chunks.push(chunk));
  req.on("end", () => {
    const body = Buffer.concat(chunks).toString("utf8");
    fs.appendFileSync(
      logPath,
      `${JSON.stringify({
        method: req.method,
        url: req.url,
        content_type: req.headers["content-type"] || null,
        authorization: req.headers.authorization ? "<redacted>" : null,
        body,
      })}\n`
    );
    res.writeHead(200, { "content-type": "application/json" });
    res.end(JSON.stringify({ success: true, result: { id: "digest_alert_email_ok" } }));
  });
});

server.listen(0, "127.0.0.1", () => {
  const address = server.address();
  fs.writeFileSync(basePath, `http://127.0.0.1:${address.port}\n`);
});

process.on("SIGTERM", () => server.close(() => process.exit(0)));
NODE
MOCK_PID=$!
trap 'kill "$MOCK_PID" >/dev/null 2>&1 || true' EXIT

for _ in $(seq 1 50); do
  [ -s "$MOCK_BASE_FILE" ] && break
  sleep 0.1
done
[ -s "$MOCK_BASE_FILE" ] || fail "controlled Cloudflare Email endpoint did not start"
EMAIL_API_BASE="$(tr -d '\n' <"$MOCK_BASE_FILE")"

log "searching copied production source cards with query: $QUERY"
"$ARCWELL_BIN" source-card search "$QUERY" >"$ARTIFACT_DIR/source-card-search.json"

SOURCE_IDS="$(node - "$ARTIFACT_DIR/source-card-search.json" <<'NODE'
const fs = require("fs");
const cards = JSON.parse(fs.readFileSync(process.argv[2], "utf8"));
if (!Array.isArray(cards) || cards.length < 3) {
  console.error(`expected at least three copied production source cards, saw ${Array.isArray(cards) ? cards.length : "not-array"}`);
  process.exit(2);
}
process.stdout.write(cards.slice(0, 3).map((card) => card.id).join("\n"));
NODE
)"
mapfile -t SOURCE_ID_ARRAY <<<"$SOURCE_IDS"

SOURCE_JSON="$(printf '%s\n' "${SOURCE_ID_ARRAY[@]}" | node -e 'const fs=require("fs"); const ids=fs.readFileSync(0,"utf8").trim().split(/\n/).filter(Boolean); process.stdout.write(JSON.stringify(ids));')"

log "authorizing controlled email recipient and storing controlled provider config"
"$ARCWELL_BIN" email authorize "$RECIPIENT" --send >"$ARTIFACT_DIR/email-authorization.json"
"$ARCWELL_BIN" secrets set-value CLOUDFLARE_ACCOUNT_ID digestalertacct --provider email >/dev/null
"$ARCWELL_BIN" secrets set-value CLOUDFLARE_EMAIL_API_TOKEN digest-alert-token --provider email >/dev/null
"$ARCWELL_BIN" secrets set-value ARCWELL_AGENT_EMAIL_FROM "$FROM" --provider email >/dev/null
"$ARCWELL_BIN" secrets set-value CLOUDFLARE_EMAIL_API_BASE "$EMAIL_API_BASE" --provider email >/dev/null

cat >"$ARCWELL_HOME/arcwell-policy.toml" <<POLICY
[[rules]]
id = "allow-digest-alert-worker-enqueue"
effect = "allow"
action = "worker.enqueue"
reason = "allow scheduled digest alert proof worker enqueue"
priority = 20

[[rules]]
id = "allow-digest-alert-delivery"
effect = "allow"
action = "digest_candidate.deliver"
package = "arcwell-x"
source = "x_digest_delivery"
channel = "email"
subject = "email:$RECIPIENT"
target = "email:$RECIPIENT"
reason = "allow scheduled digest alert proof email delivery"
priority = 20

[[rules]]
id = "allow-digest-alert-email-send"
effect = "allow"
action = "channel.send"
package = "arcwell-email"
provider = "cloudflare_email"
source = "email_send"
channel = "email"
subject = "email:$RECIPIENT"
target = "$RECIPIENT"
reason = "allow controlled scheduled digest alert email send"
priority = 20
POLICY

log "creating and approving digest candidate from copied production source cards"
"$ARCWELL_BIN" digest-candidate-create --json "{\"topic\":\"Scheduled digest alert production proof $RUN_STAMP\",\"source_card_ids\":$SOURCE_JSON}" >"$ARTIFACT_DIR/candidate.json"
CANDIDATE_ID="$(node -e 'const fs=require("fs"); const j=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(j.id)' "$ARTIFACT_DIR/candidate.json")"
"$ARCWELL_BIN" digest-candidate-approve --json "{\"id\":\"$CANDIDATE_ID\",\"reviewed_by\":\"production-proof\",\"note\":\"approved for controlled scheduled delivery proof\"}" >"$ARTIFACT_DIR/candidate-approved.json"

log "creating scheduled digest alert"
"$ARCWELL_BIN" digest-alert-schedule-create --json "{\"name\":\"digest alert proof $RUN_STAMP\",\"channel\":\"email\",\"recipient_ref\":\"email:$RECIPIENT\",\"min_score\":0,\"max_candidates\":1,\"interval_hours\":24}" >"$ARTIFACT_DIR/schedule.json"
SCHEDULE_ID="$(node -e 'const fs=require("fs"); const j=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(j.id)' "$ARTIFACT_DIR/schedule.json")"

log "draining resident worker once for scheduled delivery"
"$ARCWELL_BIN" worker run-once --max-jobs 2 >"$ARTIFACT_DIR/worker-first.json"
"$ARCWELL_BIN" digest-alert-ticks --json "{\"schedule_id\":\"$SCHEDULE_ID\"}" >"$ARTIFACT_DIR/ticks-after-first.json"
"$ARCWELL_BIN" digest-candidate-deliveries --json "{\"candidate_id\":\"$CANDIDATE_ID\"}" >"$ARTIFACT_DIR/deliveries-after-first.json"

log "draining resident worker again to prove duplicate suppression"
"$ARCWELL_BIN" worker run-once --max-jobs 2 >"$ARTIFACT_DIR/worker-second.json"
"$ARCWELL_BIN" digest-alert-ticks --json "{\"schedule_id\":\"$SCHEDULE_ID\"}" >"$ARTIFACT_DIR/ticks-after-second.json"

NOW_MINUTES="$(date -u '+%H %M' | awk '{ print ($1 * 60) + $2 }')"
START_MINUTES=$(( (NOW_MINUTES + 24 * 60 - 5) % (24 * 60) ))
END_MINUTES=$(( (NOW_MINUTES + 5) % (24 * 60) ))
START_HHMM="$(printf '%02d:%02d' $((START_MINUTES / 60)) $((START_MINUTES % 60)))"
END_HHMM="$(printf '%02d:%02d' $((END_MINUTES / 60)) $((END_MINUTES % 60)))"

log "creating quiet-hours schedule against the same candidate; it should defer before provider send"
"$ARCWELL_BIN" digest-alert-schedule-create --json "{\"name\":\"digest alert quiet proof $RUN_STAMP\",\"channel\":\"email\",\"recipient_ref\":\"email:$RECIPIENT\",\"min_score\":0,\"max_candidates\":1,\"interval_hours\":24,\"quiet_hours\":{\"timezone\":\"UTC\",\"start\":\"$START_HHMM\",\"end\":\"$END_HHMM\"}}" >"$ARTIFACT_DIR/quiet-schedule.json"
QUIET_SCHEDULE_ID="$(node -e 'const fs=require("fs"); const j=JSON.parse(fs.readFileSync(process.argv[1],"utf8")); process.stdout.write(j.id)' "$ARTIFACT_DIR/quiet-schedule.json")"
"$ARCWELL_BIN" worker run-once --max-jobs 2 >"$ARTIFACT_DIR/worker-quiet.json"
"$ARCWELL_BIN" digest-alert-ticks --json "{\"schedule_id\":\"$QUIET_SCHEDULE_ID\"}" >"$ARTIFACT_DIR/quiet-ticks.json"
"$ARCWELL_BIN" digest-candidate-deliveries --json "{\"candidate_id\":\"$CANDIDATE_ID\"}" >"$ARTIFACT_DIR/deliveries-after-quiet.json"

log "validating proof artifacts"
node - "$ARTIFACT_DIR" "$PROOF_ROOT" "$CANDIDATE_ID" "$SCHEDULE_ID" "$QUIET_SCHEDULE_ID" "$QUERY" <<'NODE'
const fs = require("fs");
const path = require("path");
const [artifactDir, proofRoot, candidateId, scheduleId, quietScheduleId, query] = process.argv.slice(2);
const read = (name) => JSON.parse(fs.readFileSync(path.join(artifactDir, name), "utf8"));
const readJsonl = (name) => {
  const file = path.join(artifactDir, name);
  if (!fs.existsSync(file) || fs.statSync(file).size === 0) return [];
  return fs.readFileSync(file, "utf8").trim().split(/\n/).filter(Boolean).map((line) => JSON.parse(line));
};
function assert(condition, message, detail) {
  if (!condition) {
    console.error(`FAIL: ${message}`);
    if (detail !== undefined) console.error(JSON.stringify(detail, null, 2));
    process.exit(1);
  }
}
const cards = read("source-card-search.json");
const candidate = read("candidate-approved.json");
const first = read("worker-first.json");
const second = read("worker-second.json");
const ticks = read("ticks-after-first.json");
const ticksSecond = read("ticks-after-second.json");
const deliveries = read("deliveries-after-first.json");
const quietWorker = read("worker-quiet.json");
const quietTicks = read("quiet-ticks.json");
const deliveriesAfterQuiet = read("deliveries-after-quiet.json");
const providerRequests = readJsonl("email-provider-requests.jsonl");

assert(cards.length >= 3, "proof must use copied production source cards", cards.length);
assert(candidate.id === candidateId && candidate.review_status === "approved", "candidate should be approved", candidate);
assert(first.digest_alert_schedule && first.digest_alert_schedule.enqueued === 1, "first worker should enqueue one digest schedule", first);
assert(first.processed === 1 && first.completed === 1, "first worker should process one completed job", first);
const job = first.jobs.find((item) => item.kind === "digest_scheduled_alert");
assert(job && job.status === "completed", "digest_scheduled_alert job should complete", first.jobs);
assert(job.result_json && job.result_json.status === "sent", "scheduled digest alert should reach sent", job);
assert(ticks.length === 1 && ticks[0].status === "sent", "scheduled tick should be sent", ticks);
assert(ticks[0].schedule_id === scheduleId, "sent tick should belong to schedule", ticks[0]);
assert(ticks[0].candidate_ids.includes(candidateId), "sent tick should record selected candidate", ticks[0]);
assert(ticks[0].delivery_ids.length === 1, "sent tick should record delivery id", ticks[0]);
assert(deliveries.length === 1 && deliveries[0].status === "sent", "digest delivery should be sent", deliveries);
assert(deliveries[0].id === ticks[0].delivery_ids[0], "delivery id should link to tick", { deliveries, ticks });
assert(second.processed === 0, "second worker pass should suppress duplicate tick inside interval", second);
assert(ticksSecond.length === 1, "duplicate pass should not create second tick", ticksSecond);
assert(providerRequests.length === 1, "controlled provider should receive exactly one email send before quiet proof", providerRequests);
assert(quietWorker.processed === 1 && quietWorker.deferred === 1, "quiet worker should defer exactly one job", quietWorker);
assert(quietTicks.length === 1 && quietTicks[0].status === "deferred", "quiet tick should be deferred", quietTicks);
assert(quietTicks[0].schedule_id === quietScheduleId, "quiet tick should belong to quiet schedule", quietTicks[0]);
assert(quietTicks[0].delivery_ids.length === 0, "quiet tick should not record provider delivery", quietTicks[0]);
assert(deliveriesAfterQuiet.length === 1, "quiet proof must not create an extra digest delivery", deliveriesAfterQuiet);
assert(readJsonl("email-provider-requests.jsonl").length === 1, "quiet proof must not add provider request");

const proofPacket = {
  proof_name: "digest-alert-scheduled-production-proof",
  proof_level: "Production Data Proof with controlled provider; not live external delivery",
  proof_root: proofRoot,
  arcwell_home: process.env.ARCWELL_HOME,
  query,
  copied_source_cards_seen: cards.length,
  candidate_id: candidateId,
  source_card_ids: candidate.source_card_ids,
  schedule_id: scheduleId,
  quiet_schedule_id: quietScheduleId,
  sent_tick_id: ticks[0].id,
  sent_delivery_id: deliveries[0].id,
  quiet_tick_id: quietTicks[0].id,
  worker: {
    first_processed: first.processed,
    first_completed: first.completed,
    duplicate_processed: second.processed,
    quiet_processed: quietWorker.processed,
    quiet_deferred: quietWorker.deferred,
  },
  gates: {
    copied_real_source_cards: true,
    reviewed_candidate_required: true,
    worker_schedule_enqueued: true,
    digest_delivery_ledger_sent: true,
    channel_delivery_attempt_linked: Boolean(deliveries[0].channel_delivery_attempt_id),
    duplicate_suppression: true,
    quiet_hours_no_send: true,
    controlled_provider_requests: providerRequests.length,
  },
  remaining_risk: [
    "This proof uses copied production source cards and a controlled Cloudflare Email endpoint, not a real external mailbox.",
    "Live external digest delivery still requires an explicit authorized recipient and live Cloudflare Email send confirmation.",
    "Long-running service recurrence is not proven by this one-shot worker proof.",
  ],
};
fs.writeFileSync(path.join(artifactDir, "proof-packet.json"), `${JSON.stringify(proofPacket, null, 2)}\n`);
console.log(JSON.stringify(proofPacket, null, 2));
NODE

printf '\n'
log "scheduled digest alert production-data proof passed"
log "proof packet: $ARTIFACT_DIR/proof-packet.json"
